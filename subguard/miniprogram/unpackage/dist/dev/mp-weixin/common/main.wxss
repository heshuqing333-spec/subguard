
page {
  min-height: 100vh;
  background: #f5f7fb;
  color: #0f172a;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}
button::after {
  border: 0;
}
.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 56rpx;
  box-sizing: border-box;
  background: #f5f7fb;
}
.title {
  color: #0f172a;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.25;
}
.subtitle {
  margin-top: 10rpx;
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.45;
}
.card {
  padding: 26rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.05);
}
.primary-btn {
  height: 76rpx;
  border-radius: 14rpx;
  background: #2563eb;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 76rpx;
}
.secondary-btn {
  height: 76rpx;
  border-radius: 14rpx;
  background: #eef2f7;
  color: #334155;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 76rpx;
}
.notice {
  margin: 18rpx 0;
  padding: 18rpx 22rpx;
  border-radius: 14rpx;
  background: #fef2f2;
  color: #b91c1c;
  font-size: 24rpx;
  line-height: 1.5;
}
.empty {
  margin-top: 28rpx;
  padding: 38rpx 30rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 16rpx;
  background: #ffffff;
  color: #64748b;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.05);
}

