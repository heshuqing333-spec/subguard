<view class="page"><view class="hero"><view class="eyebrow">SubGuard</view><view class="title">订阅管理助手</view><view class="subtitle">管理自动续费、账单导入、支出统计和取消路径。</view></view><block wx:if="{{errorMessage}}"><view class="notice">{{errorMessage}}</view></block><block wx:if="{{reminderVisible}}"><view class="card reminder-card"><view class="reminder-head"><view><view class="reminder-title">即将扣费提醒</view><view class="reminder-subtitle">未来 7 天有订阅即将自动扣费</view></view></view><view class="reminder-list"><block wx:for="{{reminderItems}}" wx:for-item="item" wx:for-index="__i0__" wx:key="id"><view data-event-opts="{{[['tap',[['viewUpcomingSubscription',['$0'],[[['reminderItems','id',item.id]]]]]]]}}" class="reminder-item" bindtap="__e"><text>{{item.name}}</text><text>{{item.next_due_date+" · ¥"+item.priceText}}</text></view></block><block wx:if="{{reminderMoreCount>0}}"><view class="reminder-more">{{'还有 '+reminderMoreCount+' 项即将扣费'}}</view></block></view><view class="reminder-actions"><button data-event-opts="{{[['tap',[['dismissUpcomingReminder',['$event']]]]]}}" class="secondary-btn reminder-btn" bindtap="__e">稍后提醒</button><button data-event-opts="{{[['tap',[['viewUpcomingSubscriptions',['$event']]]]]}}" class="primary-btn reminder-btn" bindtap="__e">查看最近订阅</button></view></view></block><view class="stats-grid"><view class="card stat-card main"><view class="stat-label">本月订阅支出</view><view class="stat-value money">{{"¥"+monthlyExpense}}</view></view><view class="card stat-card"><view class="stat-label">未来 7 天续费</view><view class="stat-value">{{upcomingCount}}</view></view><view class="card stat-card"><view class="stat-label">当前订阅总数</view><view class="stat-value">{{subscriptionCount}}</view></view></view><view class="section-title">功能入口</view><view class="entry-grid"><block wx:for="{{entrances}}" wx:for-item="item" wx:for-index="__i1__" wx:key="title"><view data-event-opts="{{[['tap',[['go',['$0'],[[['entrances','title',item.title]]]]]]]}}" class="card entry-card" bindtap="__e"><view class="entry-icon">{{item.icon}}</view><view class="entry-title">{{item.title}}</view><view class="entry-desc">{{item.desc}}</view></view></block></view><block wx:if="{{loading}}"><view class="loading">加载中...</view></block></view>