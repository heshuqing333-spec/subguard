<view class="page"><view class="title">取消路径</view><view class="subtitle">选择支付方式，查看关闭自动续费或扣费服务的入口。</view><view class="card selector"><view class="label">支付方式</view><picker range="{{payments}}" value="{{paymentIndex}}" data-event-opts="{{[['change',[['pick',['$event']]]]]}}" bindchange="__e"><view class="picker">{{selectedPayment}}</view></picker></view><block wx:if="{{errorMessage}}"><view class="notice">{{errorMessage}}</view></block><view class="card guide"><view class="top"><view><view class="platform">{{guide.platform_name}}</view><view class="method">{{guide.payment_method}}</view></view><view class="tag">{{matched?'已匹配':'通用提示'}}</view></view><block wx:for="{{guide.steps}}" wx:for-item="step" wx:for-index="index" wx:key="index"><view class="step"><view class="num">{{index+1}}</view><view class="step-text">{{step}}</view></view></block></view></view>