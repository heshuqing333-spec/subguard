<view class="page"><view class="header"><view><view class="title">订阅列表</view><view class="subtitle">查看扣费日期、支付方式和价值评分。</view></view><button data-event-opts="{{[['tap',[['add',['$event']]]]]}}" class="add-btn" bindtap="__e">添加</button></view><block wx:if="{{errorMessage}}"><view class="notice">{{errorMessage}}</view></block><block wx:if="{{$root.g0}}"><view class="empty"><view class="empty-title">还没有订阅</view><view class="empty-text">添加第一个订阅后，就能看到续费提醒和价值评分。</view><button data-event-opts="{{[['tap',[['add',['$event']]]]]}}" class="primary-btn empty-action" bindtap="__e">添加订阅</button></view></block><block wx:for="{{subscriptions}}" wx:for-item="item" wx:for-index="__i0__" wx:key="id"><view class="{{['card','sub-card',item.reminderClass]}}"><block wx:if="{{item.reminderText}}"><view class="{{['reminder','reminder-'+item.reminderClass]}}">{{item.reminderText}}</view></block><view class="top"><view><view class="name">{{item.name}}</view><view class="tag">{{item.category}}</view></view><view class="status">{{item.statusText}}</view></view><view class="price">{{"¥"+item.priceText+''}}<text class="cycle">{{"/ "+item.cycleText}}</text></view><view class="grid"><view class="info"><text>下次扣费</text><view>{{item.next_due_date||'未设置'}}</view></view><view class="info"><text>支付方式</text><view>{{item.payment_method||'未设置'}}</view></view><view class="info"><text>本月使用</text><view>{{item.usage_count+" 次"}}</view></view><view class="info"><text>重要程度</text><view>{{item.importance+" / 5"}}</view></view></view><view class="advice">{{item.valueAdvice}}</view><view class="actions"><button data-event-opts="{{[['tap',[['edit',['$0'],[[['subscriptions','id',item.id,'id']]]]]]]}}" class="secondary-btn small" bindtap="__e">编辑</button><button data-event-opts="{{[['tap',[['guide',['$0'],[[['subscriptions','id',item.id,'payment_method']]]]]]]}}" class="secondary-btn small" bindtap="__e">取消路径</button><button data-event-opts="{{[['tap',[['remove',['$0'],[[['subscriptions','id',item.id]]]]]]]}}" class="secondary-btn small danger" bindtap="__e">删除</button></view></view></block></view>