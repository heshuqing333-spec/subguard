
.tabs {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 24rpx;
}
.tab {
  height: 66rpx;
  border-radius: 14rpx;
  background: #ffffff;
  color: #64748b;
  text-align: center;
  line-height: 66rpx;
  font-size: 24rpx;
  font-weight: 700;
}
.tab.active {
  background: #2563eb;
  color: #ffffff;
}
.input-card,
.result-card,
.progress-card {
  margin-top: 20rpx;
}
textarea {
  width: 100%;
  min-height: 220rpx;
  padding: 20rpx 22rpx;
  box-sizing: border-box;
  border: 1rpx solid #cbd5e1;
  border-radius: 14rpx;
  background: #f8fafc;
  font-size: 26rpx;
  line-height: 1.45;
}
.buttons {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 18rpx;
}
.upload-title {
  color: #0f172a;
  font-size: 30rpx;
  font-weight: 800;
}
.upload-desc,
.file-name {
  margin: 10rpx 0 20rpx;
  color: #64748b;
  font-size: 23rpx;
  line-height: 1.45;
}
.progress-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 34rpx;
  padding-bottom: 34rpx;
}
.spinner {
  width: 40rpx;
  height: 40rpx;
  border: 5rpx solid #dbeafe;
  border-top-color: #2563eb;
  border-radius: 999rpx;
  -webkit-animation: spin 0.9s linear infinite;
          animation: spin 0.9s linear infinite;
}
@-webkit-keyframes spin {
from { -webkit-transform: rotate(0deg); transform: rotate(0deg);
}
to { -webkit-transform: rotate(360deg); transform: rotate(360deg);
}
}
@keyframes spin {
from { -webkit-transform: rotate(0deg); transform: rotate(0deg);
}
to { -webkit-transform: rotate(360deg); transform: rotate(360deg);
}
}
.progress-title {
  margin-top: 16rpx;
  color: #0f172a;
  font-size: 28rpx;
  font-weight: 800;
}
.progress-text {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 23rpx;
  line-height: 1.45;
  text-align: center;
}
.result-head {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 20rpx;
}
.result-title {
  font-size: 31rpx;
  font-weight: 800;
}
.result-subtitle {
  margin-top: 7rpx;
  color: #64748b;
  font-size: 23rpx;
}
.confidence {
  height: 40rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #dbeafe;
  color: #1d4ed8;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 40rpx;
}
.field {
  margin-bottom: 22rpx;
}
.field text {
  display: block;
  margin-bottom: 10rpx;
  color: #334155;
  font-size: 24rpx;
  font-weight: 700;
}
input,
.picker,
.notes {
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid #cbd5e1;
  border-radius: 14rpx;
  background: #f8fafc;
  color: #0f172a;
  font-size: 26rpx;
}
input,
.picker {
  height: 78rpx;
  padding: 0 22rpx;
  line-height: 78rpx;
}
.notes {
  min-height: 132rpx;
  padding: 18rpx 22rpx;
}
.raw-text {
  margin-bottom: 22rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  background: #f8fafc;
}
.raw-title {
  color: #64748b;
  font-size: 22rpx;
  font-weight: 700;
}
.raw-content {
  margin-top: 7rpx;
  color: #334155;
  font-size: 23rpx;
  line-height: 1.45;
}

