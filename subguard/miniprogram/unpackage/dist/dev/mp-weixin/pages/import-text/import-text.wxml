<view class="page"><view class="title">账单识别</view><view class="subtitle">支持粘贴文本或上传截图，识别后可编辑信息再添加。</view><view class="tabs"><view data-event-opts="{{[['tap',[['switchMode',['text']]]]]}}" class="{{['tab',(mode==='text')?'active':'']}}" bindtap="__e">文本识别</view><view data-event-opts="{{[['tap',[['switchMode',['image']]]]]}}" class="{{['tab',(mode==='image')?'active':'']}}" bindtap="__e">截图识别</view></view><block wx:if="{{mode==='text'}}"><view class="card input-card"><textarea disabled="{{loading}}" placeholder="例如：您已成功开通腾讯视频VIP连续包月，金额25元，将于2026-07-12自动续费。" data-event-opts="{{[['input',[['__set_model',['','text','$event',[]]]]]]}}" value="{{text}}" bindinput="__e"></textarea><view class="buttons"><button class="secondary-btn" disabled="{{loading}}" data-event-opts="{{[['tap',[['clear',['$event']]]]]}}" bindtap="__e">清空</button><button class="primary-btn" disabled="{{loading}}" data-event-opts="{{[['tap',[['recognizeText',['$event']]]]]}}" bindtap="__e">{{''+(loading?'识别中...':'开始识别')+''}}</button></view></view></block><block wx:if="{{mode==='image'}}"><view class="card input-card"><view class="upload-title">上传账单截图</view><view class="upload-desc">建议上传包含商户、金额、续费日期的清晰截图。</view><button class="primary-btn" disabled="{{loading}}" data-event-opts="{{[['tap',[['chooseImage',['$event']]]]]}}" bindtap="__e">{{''+(loading?'识别中...':'选择图片并识别')+''}}</button><block wx:if="{{imageName}}"><view class="file-name">{{"已选择："+imageName}}</view></block></view></block><block wx:if="{{loading}}"><view class="card progress-card"><view class="spinner"></view><view class="progress-title">正在识别账单</view><view class="progress-text">图片 OCR 可能需要几秒，请保持当前页面打开。</view></view></block><block wx:if="{{errorMessage&&!loading}}"><view class="notice">{{errorMessage}}</view></block><block wx:if="{{!result&&!errorMessage&&!loading}}"><view class="empty"> 识别结果会显示为可编辑表单。你可以修正名称、金额、日期和支付方式后再保存。 </view></block><block wx:if="{{result&&!loading}}"><view class="card result-card"><view class="result-head"><view><view class="result-title">识别结果</view><view class="result-subtitle">请确认并编辑后添加到订阅列表。</view></view><view class="confidence">{{result.confidenceText}}</view></view><view class="field"><text>订阅名称</text><input placeholder="订阅名称" data-event-opts="{{[['input',[['__set_model',['$0','name','$event',[]],['result']]]]]}}" value="{{result.name}}" bindinput="__e"/></view><view class="field"><text>金额</text><input type="digit" placeholder="金额" data-event-opts="{{[['input',[['__set_model',['$0','price','$event',[]],['result']]]]]}}" value="{{result.price}}" bindinput="__e"/></view><view class="field"><text>下次扣费日期</text><picker mode="date" value="{{result.next_due_date}}" data-event-opts="{{[['change',[['pickDate',['$event']]]]]}}" bindchange="__e"><view class="picker">{{result.next_due_date||'请选择日期'}}</view></picker></view><view class="field"><text>支付方式</text><picker range="{{paymentOptions}}" value="{{paymentIndex}}" data-event-opts="{{[['change',[['pickPayment',['$event']]]]]}}" bindchange="__e"><view class="picker">{{result.payment_method||'请选择支付方式'}}</view></picker></view><view class="field"><text>周期</text><picker range="{{cycleLabels}}" value="{{cycleIndex}}" data-event-opts="{{[['change',[['pickCycle',['$event']]]]]}}" bindchange="__e"><view class="picker">{{cycleLabels[cycleIndex]}}</view></picker></view><view class="field"><text>分类</text><picker range="{{categoryOptions}}" value="{{categoryIndex}}" data-event-opts="{{[['change',[['pickCategory',['$event']]]]]}}" bindchange="__e"><view class="picker">{{result.category}}</view></picker></view><view class="field"><text>备注</text><textarea class="notes" placeholder="可补充识别来源或人工备注" data-event-opts="{{[['input',[['__set_model',['$0','notes','$event',[]],['result']]]]]}}" value="{{result.notes}}" bindinput="__e"></textarea></view><block wx:if="{{rawText}}"><view class="raw-text"><view class="raw-title">OCR 原文</view><view class="raw-content">{{rawText}}</view></view></block><button class="primary-btn" disabled="{{saving}}" data-event-opts="{{[['tap',[['save',['$event']]]]]}}" bindtap="__e">{{''+(saving?'添加中...':'确认添加')+''}}</button></view></block></view>